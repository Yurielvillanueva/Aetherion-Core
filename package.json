{
  "name": "aetherion-core",
  "version": "1.0.0",
  "description": "Minecraft server website with admin panel, shop, staff list, live console, file manager, and API.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "seed": "node server/seed.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:logs": "pm2 logs aetherion-core"
  },
  "keywords": [
    "minecraft",
    "server",
    "dashboard",
    "admin",
    "express",
    "sqlite"
  ],
  "author": "Aetherion Core",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^7.0.0",
    "express-session": "^1.17.3",
    "pm2": "^5.4.3",
    "sqlite3": "^5.1.6",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
